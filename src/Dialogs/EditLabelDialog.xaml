<Window x:Class="BricsCadRc.Dialogs.EditLabelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edycja etykiety" Width="320" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Liczba prętów:" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="CountBox" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Rozstaw [mm]:" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="SpacingBox" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Oznaczenie (auto):" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="BaseMarkLabel"
                       VerticalAlignment="Center" Foreground="Gray"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Suffix (opcjonalny):" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="3" Grid.Column="1" x:Name="SuffixBox" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Podgląd:" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="PreviewLabel"
                       VerticalAlignment="Center" Foreground="Gray" FontStyle="Italic"/>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Anuluj" Width="80" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="OK"     Width="80" IsDefault="True"  Click="OK_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
