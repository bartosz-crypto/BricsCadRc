<Window x:Class="BricsCadRc.Dialogs.EditLabelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edycja etykiety" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Liczba prętów:" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="CountBox" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Rozstaw [mm]:" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="SpacingBox" VerticalAlignment="Center"/>

            <CheckBox x:Name="ShowSpacingCheck" Grid.Row="2" Grid.ColumnSpan="2"
                      Content="Pokaż rozstaw w oznaczeniu" Margin="0,4,0,4"
                      Checked="ShowSpacingCheck_Changed"
                      Unchecked="ShowSpacingCheck_Changed"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Oznaczenie (auto):" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="BaseMarkLabel"
                       VerticalAlignment="Center" Foreground="Gray"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Suffix (opcjonalny):" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="4" Grid.Column="1" x:Name="SuffixBox" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Podgląd:" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="PreviewLabel"
                       VerticalAlignment="Center" Foreground="Gray" FontStyle="Italic"/>
        </Grid>

        <TextBlock Text="Widoczność prętów:" FontWeight="Bold" Margin="0,8,0,4"/>
        <WrapPanel>
            <RadioButton x:Name="RbAll"       Content="Wszystkie"        GroupName="vis" Margin="0,0,12,4" IsChecked="True"/>
            <RadioButton x:Name="RbMiddle"    Content="Środkowy"         GroupName="vis" Margin="0,0,12,4"/>
            <RadioButton x:Name="RbFirstLast" Content="Pierwszy+Ostatni" GroupName="vis" Margin="0,0,12,4"/>
            <RadioButton x:Name="RbManual"    Content="Manualny"         GroupName="vis" Margin="0,0,0,4"/>
        </WrapPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Anuluj" Width="80" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="OK"     Width="80" IsDefault="True"  Click="OK_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
