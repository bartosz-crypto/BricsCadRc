<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="BricsCadRc.Dialogs.BarScheduleDialog"
    Title="Bar Bending Schedule"
    Width="860" Height="520"
    MinWidth="600" MinHeight="350"
    WindowStartupLocation="CenterScreen"
    Background="#F0F0F0">

    <Window.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E5FA8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <Border Grid.Row="0" Background="#1E5FA8" CornerRadius="3" Padding="10,6">
            <TextBlock Text="Bar Bending Schedule — BS 8666:2020"
                       Foreground="White" FontSize="14" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0"/>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  x:Name="ScheduleGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#EBF0F8"
                  RowBackground="White"
                  BorderBrush="#AAAAAA"
                  BorderThickness="1"
                  SelectionMode="Single"
                  HeadersVisibility="Column">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Pos." Binding="{Binding PosNr}"
                                    Width="50"/>
                <DataGridTextColumn Header="Mark" Binding="{Binding Mark}"
                                    Width="90"/>
                <DataGridTextColumn Header="Shape" Binding="{Binding ShapeCode}"
                                    Width="55"/>
                <DataGridTextColumn Header="Dia. [mm]" Binding="{Binding Diameter}"
                                    Width="70"/>
                <DataGridTextColumn Header="A [mm]" Binding="{Binding ColA}"
                                    Width="65"/>
                <DataGridTextColumn Header="B [mm]" Binding="{Binding ColB}"
                                    Width="65"/>
                <DataGridTextColumn Header="C [mm]" Binding="{Binding ColC}"
                                    Width="65"/>
                <DataGridTextColumn Header="D [mm]" Binding="{Binding ColD}"
                                    Width="65"/>
                <DataGridTextColumn Header="E [mm]" Binding="{Binding ColE}"
                                    Width="65"/>
                <DataGridTextColumn Header="Cut Length [mm]" Binding="{Binding ColLength}"
                                    Width="100"/>
                <DataGridTextColumn Header="No. Bars" Binding="{Binding TotalCount}"
                                    Width="70"/>
                <DataGridTextColumn Header="Mass [kg]" Binding="{Binding ColMass}"
                                    Width="75"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Podsumowanie -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="Total mass:" FontWeight="Bold" Margin="0,0,8,0"/>
            <TextBlock x:Name="TotalMassText" Text="0.00 kg"
                       FontWeight="Bold" Foreground="#1E5FA8"/>
        </StackPanel>

        <!-- Przyciski -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right"
                    FlowDirection="RightToLeft">
            <Button Content="Close" Click="Close_Click"/>
            <Button Content="Export CSV" Click="ExportCsv_Click"
                    Margin="0,0,8,0"/>
        </StackPanel>
    </Grid>
</Window>
