<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="BricsCadRc.Dialogs.BarScheduleDialog"
    Title="Bar Bending Schedule"
    Width="860" Height="520"
    MinWidth="600" MinHeight="350"
    WindowStartupLocation="CenterScreen"
    Background="#F0F0F0">

    <Window.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E5FA8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <Border Grid.Row="0" Background="#1E5FA8" CornerRadius="3" Padding="10,6">
            <TextBlock Text="Bar Bending Schedule — BS 8666:2020"
                       Foreground="White" FontSize="14" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0"/>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  x:Name="ScheduleGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#EBF0F8"
                  RowBackground="White"
                  BorderBrush="#AAAAAA"
                  BorderThickness="1"
                  SelectionMode="Extended"
                  SelectionUnit="CellOrRowHeader"
                  ClipboardCopyMode="IncludeHeader"
                  HeadersVisibility="Column">

            <DataGrid.Columns>
                <DataGridTextColumn Header="BAR MARK"        Binding="{Binding PosNr}"         Width="90"/>
                <DataGridTextColumn Header="TYPE &amp; SIZE" Binding="{Binding TypeAndSize}"    Width="90"/>
                <DataGridTextColumn Header="NO. OF MEMBERS"  Binding="{Binding NoOfMembers}"   Width="110"/>
                <DataGridTextColumn Header="NO. IN EACH"     Binding="{Binding TotalCount}"    Width="90"/>
                <DataGridTextColumn Header="TOTAL NO. BARS"  Binding="{Binding TotalNoBarsStr}" Width="110"/>
                <DataGridTextColumn Header="LENGTH PER BAR"  Binding="{Binding ColLength}"     Width="110"/>
                <DataGridTextColumn Header="CODE"            Binding="{Binding ShapeCode}"     Width="60"/>
                <DataGridTextColumn Header="A"               Binding="{Binding ColA}"          Width="70"/>
                <DataGridTextColumn Header="B"               Binding="{Binding ColB}"          Width="70"/>
                <DataGridTextColumn Header="C"               Binding="{Binding ColC}"          Width="70"/>
                <DataGridTextColumn Header="D"               Binding="{Binding ColD}"          Width="70"/>
                <DataGridTextColumn Header="E/R"             Binding="{Binding ColE}"          Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Podsumowanie -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="Total mass:" FontWeight="Bold" Margin="0,0,8,0"/>
            <TextBlock x:Name="TotalMassText" Text="0.00 kg"
                       FontWeight="Bold" Foreground="#1E5FA8"/>
        </StackPanel>

        <!-- Przyciski -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right"
                    FlowDirection="RightToLeft">
            <Button Content="Close" Click="Close_Click"/>
            <Button Content="Export CSV" Click="ExportCsv_Click"
                    Margin="0,0,8,0"/>
        </StackPanel>
    </Grid>
</Window>
