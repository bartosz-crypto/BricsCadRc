<Window x:Class="BricsCadRc.Dialogs.PunchingSummaryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RC_PUNCHING_SUMMARY_BARS — preview"
        Height="280" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="6"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="8"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="6"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="8"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" FontWeight="Bold"
               Text="Computed pile counts:"/>

    <Border Grid.Row="2" BorderBrush="#BBB" BorderThickness="1"
            Background="#F8F8F8" Padding="8,4">
      <TextBlock x:Name="PhCountsBlock"
                 FontFamily="Consolas" FontSize="12"/>
    </Border>

    <TextBlock Grid.Row="4" FontWeight="Bold"
               Text="Summary bars to generate:"/>

    <Border Grid.Row="6" BorderBrush="#BBB" BorderThickness="1"
            Background="#F8F8F8" Padding="8,4">
      <TextBlock x:Name="SummaryBlock"
                 FontFamily="Consolas" FontSize="12"/>
    </Border>

    <TextBlock Grid.Row="8" FontStyle="Italic" FontSize="11"
               Foreground="#555" Margin="0,4,0,0" TextWrapping="Wrap"
               Text="Click OK and place each bar by clicking N points in the drawing (1 point per position)."/>

    <StackPanel Grid.Row="9" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button x:Name="OkButton" Content="OK" Width="80" Margin="0,0,6,0"
              IsDefault="True" Click="OkButton_Click"/>
      <Button Content="Cancel" Width="80"
              IsCancel="True" Click="CancelButton_Click"/>
    </StackPanel>
  </Grid>
</Window>
