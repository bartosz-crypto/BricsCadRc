<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="BricsCadRc.Dialogs.BarElevationDialog"
    Title="Reinforcement – Elevation"
    Width="400" Height="480"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Background="#F0F0F0">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: Header -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>   <!-- 2: Diameter -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>   <!-- 4: PosNr -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>   <!-- 6: Shape button -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>   <!-- 8: Layer -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>   <!-- 10: "Shape parameters:" header -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>   <!-- 12: Param A -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>   <!-- 14: Param B -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>   <!-- 16: Param C -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>   <!-- 18: Param D -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>   <!-- 20: Param E -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>   <!-- 22: Total length -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>   <!-- 24: Buttons -->
        </Grid.RowDefinitions>

        <!-- Naglowek -->
        <Border Grid.Row="0" Background="#1E5FA8" CornerRadius="3" Padding="8,6">
            <TextBlock Text="Reinforcement – Elevation" Foreground="White"
                       FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0"/>
        </Border>

        <!-- Diameter -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Diameter:"/>
            <ComboBox Grid.Column="1" x:Name="DiameterCombo"
                      SelectionChanged="DiameterCombo_SelectionChanged">
                <ComboBoxItem Content="H6"  Tag="6"/>
                <ComboBoxItem Content="H8"  Tag="8"/>
                <ComboBoxItem Content="H10" Tag="10"/>
                <ComboBoxItem Content="H12" Tag="12" IsSelected="True"/>
                <ComboBoxItem Content="H16" Tag="16"/>
                <ComboBoxItem Content="H20" Tag="20"/>
                <ComboBoxItem Content="H25" Tag="25"/>
                <ComboBoxItem Content="H32" Tag="32"/>
            </ComboBox>
        </Grid>

        <!-- PosNr -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Numer pozycji:"/>
            <TextBox   Grid.Column="1" x:Name="PosNrBox"/>
        </Grid>

        <!-- Shape button -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Shape code:"/>
            <Button Grid.Column="1" x:Name="ShapeBtn"
                    Content="[00] Straight ▼"
                    HorizontalContentAlignment="Left"
                    Padding="6,0"
                    Click="ShapeBtn_Click"/>
        </Grid>

        <!-- Layer -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Layer:"/>
            <ComboBox Grid.Column="1" x:Name="LayerCombo">
                <ComboBoxItem Content="Bottom Layer" Tag="BOT" IsSelected="True"/>
                <ComboBoxItem Content="Top Layer"    Tag="TOP"/>
            </ComboBox>
        </Grid>

        <!-- Shape parameters header -->
        <TextBlock Grid.Row="10" Text="Shape parameters:" FontWeight="SemiBold"/>

        <!-- Param A -->
        <Grid Grid.Row="12" x:Name="RowA">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="LabelA" Text="A [mm]:"/>
            <TextBox   Grid.Column="1" x:Name="ParamABox" Text="3000"
                       TextChanged="ParamBox_TextChanged"/>
        </Grid>

        <!-- Param B -->
        <Grid Grid.Row="14" x:Name="RowB" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="LabelB" Text="B [mm]:"/>
            <TextBox   Grid.Column="1" x:Name="ParamBBox" Text="200"
                       TextChanged="ParamBox_TextChanged"/>
        </Grid>

        <!-- Param C -->
        <Grid Grid.Row="16" x:Name="RowC" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="LabelC" Text="C [mm]:"/>
            <TextBox   Grid.Column="1" x:Name="ParamCBox" Text="200"
                       TextChanged="ParamBox_TextChanged"/>
        </Grid>

        <!-- Param D -->
        <Grid Grid.Row="18" x:Name="RowD" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="LabelD" Text="D [mm]:"/>
            <TextBox   Grid.Column="1" x:Name="ParamDBox" Text="200"
                       TextChanged="ParamBox_TextChanged"/>
        </Grid>

        <!-- Param E -->
        <Grid Grid.Row="20" x:Name="RowE" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="LabelE" Text="E [mm]:"/>
            <TextBox   Grid.Column="1" x:Name="ParamEBox" Text="200"
                       TextChanged="ParamBox_TextChanged"/>
        </Grid>

        <!-- Total length -->
        <Grid Grid.Row="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Total length [mm]:"/>
            <TextBox   Grid.Column="1" x:Name="TotalLengthBox"
                       IsReadOnly="True" Background="#F5F5F5"
                       TextChanged="TotalLengthBox_TextChanged"/>
            <CheckBox  Grid.Column="2" x:Name="OverrideCheck"
                       Content="Override" VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Checked="OverrideCheck_Changed"
                       Unchecked="OverrideCheck_Changed"/>
        </Grid>

        <!-- Przyciski -->
        <StackPanel Grid.Row="24" Orientation="Horizontal" HorizontalAlignment="Right"
                    FlowDirection="RightToLeft" Margin="0,8,0,0">
            <Button Content="Cancel" Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="OK" Click="OK_Click"
                    Background="#1E5FA8" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
