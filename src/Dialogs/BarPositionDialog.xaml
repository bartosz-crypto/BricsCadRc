<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="BricsCadRc.Dialogs.BarPositionDialog"
    Title="Reinforcement description"
    Width="340" Height="175"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Background="#F0F0F0">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Naglowek -->
        <Border Grid.Row="0" Background="#1E5FA8" CornerRadius="3" Padding="8,5">
            <TextBlock x:Name="PreviewText" Text="H12"
                       Foreground="White" FontSize="13" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0"/>
        </Border>

        <!-- Numer pozycji -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Position number:"/>
            <TextBox Grid.Column="1" x:Name="PositionBox"/>
        </Grid>

        <!-- Opis -->
        <TextBlock Grid.Row="4" Text="Enter the position number for this bar."
                   Foreground="#666" FontSize="11" TextWrapping="Wrap"/>

        <!-- Przyciski -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right"
                    FlowDirection="RightToLeft">
            <Button Content="Cancel" Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="OK" Click="OK_Click"
                    Background="#1E5FA8" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
