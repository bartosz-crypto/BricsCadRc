<Window x:Class="BricsCadRc.Dialogs.EditDistributionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edycja rozkładu" Width="300" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Mark (readonly) -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Pozycja:" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="MarkLabel" VerticalAlignment="Center" FontWeight="Bold"/>

            <!-- Count -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Liczba prętów:" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="CountBox" VerticalAlignment="Center"/>

            <!-- Spacing -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Rozstaw [mm]:" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="SpacingBox" VerticalAlignment="Center"/>

            <!-- Cover -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Otulina [mm]:" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="3" Grid.Column="1" x:Name="CoverBox" VerticalAlignment="Center"/>

            <!-- BarsSpan (obliczany, readonly) -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Rozpiętość [mm]:" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="SpanLabel" VerticalAlignment="Center" Foreground="Gray"/>

            <CheckBox x:Name="CbAddAnnotation" Grid.Row="5" Grid.ColumnSpan="2"
                      Content="Dodaj opis rozkładu" Margin="0,8,0,0"
                      Visibility="Collapsed"/>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Anuluj" Width="80" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click"/>
<Button Content="OK"     Width="80" IsDefault="True"  Click="OK_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
